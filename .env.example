# ──────────────────────────────────────────────────────────────────
#  QUIPU — Variables de entorno del workspace
# ──────────────────────────────────────────────────────────────────
#  Cada subproyecto (frontend/backend/contracts) tiene su propio
#  .env.example con las variables específicas. Este archivo solo
#  documenta las variables compartidas y dónde se usan.
# ──────────────────────────────────────────────────────────────────

# Compartidas en TODOS los entornos
NODE_ENV="development"

# RPC de Avalanche (usado por frontend, backend y contratos)
NEXT_PUBLIC_RPC_URL="https://api.avax-test.network/ext/bc/C/rpc"
NEXT_PUBLIC_CHAIN_ID="43113"

# Direcciones de contratos desplegados (rellenar tras deploy)
NEXT_PUBLIC_SCORE_REGISTRY_ADDRESS=""
NEXT_PUBLIC_ATTESTATION_REGISTRY_ADDRESS=""
NEXT_PUBLIC_SCORING_ENGINE_ADDRESS=""
NEXT_PUBLIC_LENDING_POOL_ADDRESS=""

# Ver:
#   - frontend/.env.example  → vars públicas (NEXT_PUBLIC_*)
#   - backend/.env.example   → DB, Privy secret, Reclaim secret, oracle key
#   - contracts/.env.example → deployer private key, etherscan key
