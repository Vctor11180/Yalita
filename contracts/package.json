{
  "name": "@yalita/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:gas": "forge test --gas-report",
    "coverage": "forge coverage",
    "fmt": "forge fmt",
    "deploy:fuji": "forge script script/Deploy.s.sol --rpc-url fuji --broadcast --verify --slow",
    "deploy:local": "forge script script/Deploy.s.sol --rpc-url http://localhost:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80",
    "verify:fuji": "forge verify-contract --chain-id 43113 --watch",
    "anvil": "anvil --host 0.0.0.0",
    "install:deps": "forge install OpenZeppelin/openzeppelin-contracts@v5.0.2 --no-commit && forge install foundry-rs/forge-std --no-commit",
    "clean": "forge clean",
    "lint": "forge fmt --check",
    "typecheck": "echo 'contracts: no typecheck'"
  }
}
