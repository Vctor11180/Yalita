# ── Base de datos (Neon) ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/quipu?sslmode=require"
DIRECT_URL="postgresql://user:password@host/quipu?sslmode=require"

# ── Servidor ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
ALLOWED_ORIGIN="http://localhost:3000"

# ── Privy (auth) ──────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID="your_privy_app_id"
PRIVY_APP_SECRET="your_privy_app_secret"

# ── Reclaim Protocol (zkTLS oracle) ───────────────────────────────
RECLAIM_APP_ID=""
RECLAIM_APP_SECRET=""

# ── Blockchain ────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL="https://api.avax-test.network/ext/bc/C/rpc"
NEXT_PUBLIC_CHAIN_ID=43113

# Private key del oracle (firma attestations on-chain). DIFERENTE del deployer.
ORACLE_PRIVATE_KEY="0x..."

# Direcciones de contratos (rellenar tras deploy)
NEXT_PUBLIC_SCORE_REGISTRY_ADDRESS=""
NEXT_PUBLIC_ATTESTATION_REGISTRY_ADDRESS=""
NEXT_PUBLIC_SCORING_ENGINE_ADDRESS=""
NEXT_PUBLIC_LENDING_POOL_ADDRESS=""
